{
  "name": "rhopenclaw-desktop",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "node scripts/start-dev.mjs",
    "desktop:dev:windows": "scripts\\start-dev-windows.cmd",
    "desktop:package:mac:arm64": "bash scripts/package-mac-arm64.sh",
    "desktop:package:mac:x64": "bash scripts/package-mac-x64.sh",
    "desktop:package:win:x64": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/package-win-x64.ps1",
    "desktop:prepare:mac:arm64:full-offline": "node scripts/build-full-offline-materials.mjs --platform=darwin --arch=arm64 --full-platform-label=macos-arm64",
    "desktop:prepare:mac:x64:full-offline": "node scripts/build-full-offline-materials.mjs --platform=darwin --arch=x64 --full-platform-label=macos-x64",
    "desktop:prepare:win:x64:full-offline": "node scripts/build-full-offline-materials.mjs --platform=win --arch=x64 --full-platform-label=windows-x64",
    "evidence:collect:macos": "bash scripts/collect-upgrade-evidence-macos.sh",
    "evidence:collect:windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/collect-upgrade-evidence-windows.ps1",
    "tauri:doctor": "node scripts/check-tauri-toolchain.mjs",
    "tauri:check": "node scripts/tauri-build-check.mjs",
    "release:bundle-extras": "node scripts/generate-release-bundle-extras.mjs",
    "release:normalize": "node scripts/normalize-release-artifacts.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:package": "npm run tauri:doctor && npm run tauri:build && npm run release:bundle-extras && npm run release:normalize",
    "openclaw:install-cn": "bash scripts/install-cn.sh",
    "openclaw:prepare-mirror-assets": "node scripts/build-openclaw-bootstrap-assets.mjs",
    "release:manifest": "node scripts/generate-release-manifest.mjs",
    "release:verify": "node scripts/verify-release-artifacts.mjs",
    "release:report": "npm run release:manifest && npm run release:verify",
    "release:summary": "node scripts/generate-release-summary.mjs",
    "release:gate": "node scripts/check-release-readiness.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.9.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
