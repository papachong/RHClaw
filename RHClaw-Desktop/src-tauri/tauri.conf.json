{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RHClaw Desktop",
  "version": "1.0.1",
  "identifier": "com.rhopenclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RHClaw Desktop",
        "width": 1120,
        "height": 780
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": [
      "../release/openclaw-bootstrap/full-offline-only/**/*",
      "skills/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGNEI0OTkzQkFCOENGQ0YKUldUUHo3aTZrMGxMSDJIVkYvNUhZNXV4eFJydVUvaERzWnpGS3ZuK0VZa1ZWZGZXVlQwSnpaelAK"
    }
  }
}